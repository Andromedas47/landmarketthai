# n8n Webhook (async side-effects)
N8N_WEBHOOK_LEADS=https://your-n8n.com/webhook/leads

# Site
NEXT_PUBLIC_SITE_URL=https://landmarketthai.com
NEXT_PUBLIC_LINE_OA_URL=https://line.me/R/oa/@landmarketthai
